# COmbinations 
def combinations(nums, k):
    result = []
    def backtrack(start, path):
        if len(path) == k:
            result.append(path.copy())
            return
        for i in range(start, len(nums)):
            path.append(nums[i])
            backtrack(i + 1, path)
            path.pop()
    backtrack(0, [])
    return result
