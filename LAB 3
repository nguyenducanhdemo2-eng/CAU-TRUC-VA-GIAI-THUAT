# SUBSET KHÔNG PRUNING
def subset_sum_basic(nums, target):
    result = []
    def backtrack(start, path, current_sum):
       # Base Case
        if current_sum == target:
            result.append(path.copy())
            return
        # Thử các số tiếp theo
        for i in range(start, len(nums)):
            # CHOOSE
            path.append(nums[i])
            # EXPLORE
            backtrack(i + 1, path, current_sum + nums[i])
            # UNCHOOSE
            path.pop()
    backtrack(0, [], 0)
    return result
# SUBSET CÓ PRUNING
def subset_sum_pruning(nums, target):
    nums.sort()
    result = []
    def backtrack(start, path, current_sum):
        # Pruning 1
        if current_sum > target:
            return
        # Base Case
        if current_sum == target:
            result.append(path.copy())
            return
        for i in range(start, len(nums)):
            # Pruning 3
            if i > start and nums[i] == nums[i-1]:
                continue
            # Pruning 2
            if current_sum + nums[i] > target:
                break
            # Pruning 4
            remaining_sum = sum(nums[i:])
            if current_sum + remaining_sum < target:
                break
            path.append(nums[i])
            backtrack(
                i + 1,
                path,
                current_sum + nums[i]
            )
            path.pop()
    backtrack(0, [], 0)
    return result
