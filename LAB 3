# Binary_String(n)
def binary_string(n):
    result = []
    def backtrack(path):
        if len(path) == n:
            result.append("".join(path))
            return
        for choice in ['0', '1']:
            path.append(choice)
            backtrack(path)
            path.pop()
    backtrack([])
    return result
