# Part B - Coin Change DP

def coin_change_dp(amount, coins):

    dp = [float('inf')] * (amount + 1)

    dp[0] = 0

    for i in range(1, amount + 1):

        for coin in coins:

            if coin <= i:
                dp[i] = min(dp[i], dp[i-coin] + 1)

    if dp[amount] == float('inf'):
        return -1

    return dp[amount]
def coin_change_greedy(amount, coins):

    coins = sorted(coins, reverse=True)

    count = 0
    detail = []

    for coin in coins:

        while amount >= coin:
            amount -= coin
            count += 1
            detail.append(coin)

    if amount == 0:
        return count, detail

    return -1, []

