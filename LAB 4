#  Fractional Knapsack

def fractional_knapsack(capacity, items):
    """
    Greedy theo value/weight
    """
    items_ratio = []
    for weight, value in items:
        ratio = value / weight
        items_ratio.append((weight, value, ratio))
    items_ratio.sort(key=lambda x: x[2], reverse=True)
    total_value = 0
    remaining = capacity
    selected = []
    for weight, value, ratio in items_ratio:
        if remaining == 0:
            break
        if weight <= remaining:
            total_value += value
            remaining -= weight
            selected.append((weight, value, 1.0))
        else:
            fraction = remaining / weight
            total_value += value * fraction
            selected.append((weight, value, fraction))
            remaining = 0
    return total_value, selected
