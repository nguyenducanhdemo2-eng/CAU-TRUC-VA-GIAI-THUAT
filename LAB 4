import heapq
import time

# Part A - Meeting Rooms

def min_meeting_rooms(meetings):

    if not meetings:
        return 0

    meetings.sort(key=lambda x: x[0])

    heap = []

    heapq.heappush(heap, meetings[0][1])

    for start, end in meetings[1:]:

        if start >= heap[0]:
            heapq.heappop(heap)

        heapq.heappush(heap, end)

    return len(heap)

