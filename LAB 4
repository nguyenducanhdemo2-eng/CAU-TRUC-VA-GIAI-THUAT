# Bài 1.2 - Coin Change Greedy

def coin_change_greedy(amount, coins):
    """
    Đổi tiền bằng Greedy
    Luôn chọn đồng lớn nhất có thể
    """
    coins = sorted(coins, reverse=True)
    count = 0
    used = []
    for coin in coins:
        while amount >= coin:
            amount -= coin
            count += 1
            used.append(coin)
    if amount == 0:
        return count, used
    return -1, []

