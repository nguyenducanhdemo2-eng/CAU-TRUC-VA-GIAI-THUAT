#  Compare

def compare_coin_change(amount, coins):

    print("\n" + "="*50)

    print(f"amount={amount}")
    print(f"coins={coins}")

    print("\nGREEDY")

    start = time.time()

    g_result, g_detail = coin_change_greedy(amount, coins)

    g_time = time.time() - start

    print("Result:", g_result)
    print("Detail:", g_detail)
    print("Time:", g_time)

    print("\nDP")

    start = time.time()

    dp_result = coin_change_dp(amount, coins)

    dp_time = time.time() - start

    print("Result:", dp_result)
    print("Time:", dp_time)

    print("\nCOMPARISON")

    if g_result == dp_result:
        print("Greedy đúng")
    else:
        print("Greedy sai")

    if g_time > 0:
        print("Speedup =", dp_time/g_time)

